<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 监控：UsageStats 权限 -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />
    <!-- 锁机：悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 前台服务权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- 精准闹钟 (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- 电池优化白名单 (MIUI 省电策略=无限制) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 通知权限 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 全屏通知 (从后台弹出 Activity) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- 开机广播 (重新安排定时锁屏) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- 查询已安装应用 -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".TimeLockApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TimeLock">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleInstance"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:theme="@style/Theme.TimeLock">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 透明代理: 从 Service 启动 Home -->
        <activity
            android:name=".ui.HomeProxyActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- 前台监控服务 -->
        <service
            android:name=".service.LockMonitorService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- 锁机覆盖层服务 -->
        <service
            android:name=".service.LockOverlayService"
            android:exported="false" />

        <!-- AlarmManager 唤醒接收器（进程死后仍可接收） -->
        <receiver
            android:name=".service.LockCheckReceiver"
            android:exported="false" />

        <!-- 定时锁屏闹钟接收器 -->
        <receiver
            android:name=".service.ScheduledLockReceiver"
            android:exported="false" />

        <!-- 开机广播接收器：重新安排定时锁屏闹钟 -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- APP 安装/卸载广播：增量更新已安装应用缓存 -->
        <receiver
            android:name=".util.PackageChangeReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- 无障碍服务 (实时前台 APP 监控, MIUI 唯一可靠方案) -->
        <service
            android:name=".service.LockAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
